    "@types/cytoscape": "^3.21.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
